@model AdminPortal.Models.ResetPasswordRequest
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <h2 class="mb-3">إعادة تعيين كلمة المرور لمستخدم</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (ViewBag.GeneratedPassword != null)
    {
        <div class="alert alert-info">
            <strong>كلمة المرور الجديدة:</strong>
            <code>@ViewBag.GeneratedPassword</code>
            <br />
            يرجى إرسال هذه الكلمة للمستخدم وتغييرها لاحقاً من قبله.
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="ResetUserPassword" method="post">
                <div class="mb-3">
                    <label asp-for="UserId" class="form-label">معرّف المستخدم (UserId)</label>
                    <input asp-for="UserId" class="form-control" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">كلمة مرور جديدة (اختياري)</label>
                    <input asp-for="NewPassword" class="form-control" type="text"
                           placeholder="اتركه فارغاً ليتم توليد كلمة مرور تلقائياً" />
                </div>

                <button type="submit" class="btn btn-primary">إعادة التعيين</button>
            </form>
        </div>
    </div>
</div>


